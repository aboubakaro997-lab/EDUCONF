# Production environment variables (root)

POSTGRES_DB=educonf
POSTGRES_USER=educonf
POSTGRES_PASSWORD=change-this-postgres-password

DATABASE_URL=postgresql://educonf:change-this-postgres-password@postgres:5432/educonf

SECRET_KEY=replace-with-long-random-secret-at-least-32-chars
REFRESH_SECRET_KEY=replace-with-another-long-random-secret-at-least-32-chars

ALLOWED_ORIGINS=https://your-domain.com
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

RATE_LIMIT_LOGIN_ATTEMPTS=10
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_REGISTER_ATTEMPTS=5
RATE_LIMIT_REGISTER_WINDOW_SECONDS=600
REDIS_URL=redis://redis:6379/0

FRONTEND_PORT=8080

# JSON array string (optional but recommended in production with TURN)
# REACT_APP_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.your-domain.com:3478","username":"turnuser","credential":"turnpass"}]
REACT_APP_ICE_SERVERS=
