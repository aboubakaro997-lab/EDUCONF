# Backend environment example

APP_NAME=EduConf CI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Use PostgreSQL in production
# DATABASE_URL=postgresql://postgres:password@localhost:5432/educonf
DATABASE_URL=sqlite:///./educonf.db

SECRET_KEY=change-me-access-secret
REFRESH_SECRET_KEY=change-me-refresh-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma separated list
ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1

RATE_LIMIT_LOGIN_ATTEMPTS=10
RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
RATE_LIMIT_REGISTER_ATTEMPTS=5
RATE_LIMIT_REGISTER_WINDOW_SECONDS=600
REDIS_URL=
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
